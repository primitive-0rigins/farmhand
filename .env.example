# Public-safe example values only.
# Do not commit real farm addresses, customer data, API keys, or credentials.

FARMHAND_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FARMHAND_DATABASE_URL=sqlite:///./farmhand.db
# Use `nws` for live keyless US weather; `demo` remains the offline default.
FARMHAND_WEATHER_PROVIDER=demo
# Set only for local browser development; never enable in production.
FARMHAND_DEV_AUTH=0
# Configure all of these to enable SMTP magic-link delivery in production.
# FARMHAND_SMTP_HOST=smtp.example.com
# FARMHAND_SMTP_PORT=587
# FARMHAND_SMTP_SENDER=hello@example.com
# FARMHAND_SMTP_USERNAME=...
# FARMHAND_SMTP_PASSWORD=...
# FARMHAND_APP_URL=https://farmhand.example.com
VITE_API_BASE_URL=http://localhost:8000
